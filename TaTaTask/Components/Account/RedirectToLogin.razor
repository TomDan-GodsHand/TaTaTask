@inject NavigationManager Nav

@code {
    protected override void OnInitialized()
    {
        var returnUrl = Nav.ToBaseRelativePath(Nav.Uri);
        var url = string.IsNullOrEmpty(returnUrl)
            ? "login"
            : $"login?returnUrl={Uri.EscapeDataString(returnUrl)}";
        Nav.NavigateTo(url);
    }
}
